# Copy to .env and set production values.

DATABASE_URL=sqlite:///./data/app.db
REDIS_URL=redis://redis:6379/0
INGEST_DIR=/app/incoming
OBJECT_STORE_ROOT=/app/data
OBJECT_STORE_RECEIPTS_PREFIX=receipts

# API / AI / YNAB credentials
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
YNAB_ACCESS_TOKEN=
YNAB_BUDGET_ID=
YNAB_DEFAULT_ACCOUNT_ID=

# CORS and frontend URL routing
CORS_ORIGINS=["https://receipts.example.com"]
NEXT_PUBLIC_API_BASE_URL=/api
