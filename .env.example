GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_PROMPT=Categorize receipt line items into the most appropriate YNAB categories.

YNAB_ACCESS_TOKEN=your_ynab_personal_access_token
YNAB_BUDGET_ID=your_budget_id
YNAB_DEFAULT_ACCOUNT_ID=optional_default_account_id
YNAB_CACHE_REFRESH_INTERVAL_MINUTES=30

DATABASE_URL=sqlite:///./data/app.db
REDIS_URL=redis://localhost:6379/0

INGEST_DIR=./data/ingest
OBJECT_STORE_ROOT=./data
OBJECT_STORE_RECEIPTS_PREFIX=receipts
LOG_FILE_PATH=./data/logs/app.log

SCAN_INTERVAL_SECONDS=10
STABLE_CHECKS_REQUIRED=2
STABLE_MIN_AGE_SECONDS=3

GAME_GREEN_HOURS_THRESHOLD=24
GAME_BROWN_HOURS_THRESHOLD=72
GAME_TOKEN_EARN_EVERY_GREENS=3
GAME_SHRED_DAILY_SPEND_CAP=0
GAME_GREEN_RATIO_TARGET_PERCENT=70
GAME_STREAK_CHALLENGE_TARGET=6
GAME_SHRED_CHALLENGE_TARGET=2

CORS_ORIGINS=["http://localhost:3000"]
NEXT_PUBLIC_API_BASE_URL=/api
