GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_PROMPT=Categorize receipt line items into the most appropriate YNAB categories.

YNAB_ACCESS_TOKEN=your_ynab_personal_access_token
YNAB_BUDGET_ID=your_budget_id
YNAB_DEFAULT_ACCOUNT_ID=optional_default_account_id

DATABASE_URL=sqlite:///./data/app.db
REDIS_URL=redis://localhost:6379/0

INGEST_DIR=./data/ingest
OBJECT_STORE_ROOT=./data
OBJECT_STORE_RECEIPTS_PREFIX=receipts

SCAN_INTERVAL_SECONDS=10
STABLE_CHECKS_REQUIRED=2
STABLE_MIN_AGE_SECONDS=3

CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
